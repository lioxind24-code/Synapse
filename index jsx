  { id: "t1", title: "Send follow-up emails to 12 leads from last week", type: "email", status: "awaiting_approval", confidence: 82, actionLevel: "l2", createdAt: "2 min ago", integrations: ["Gmail", "HubSpot"] },
  { id: "t2", title: "Schedule Q1 planning meeting with leadership team", type: "calendar", status: "completed", confidence: 95, actionLevel: "l1", createdAt: "14 min ago", integrations: ["Google Calendar", "Slack"] },
  { id: "t3", title: "Research competitors' pricing and prepare report", type: "research", status: "executing", confidence: 78, actionLevel: "l1", createdAt: "32 min ago", integrations: ["Web"] },
  { id: "t4", title: "Update CRM records for all closed deals this month", type: "crm", status: "pending", confidence: 71, actionLevel: "l2", createdAt: "1 hr ago", integrations: ["Salesforce"] },
  { id: "t5", title: "Send invoice to Acme Corp for November services", type: "document", status: "awaiting_approval", confidence: 61, actionLevel: "l3", createdAt: "2 hr ago", integrations: ["Gmail", "Stripe"] },
