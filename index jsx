const MOCK_APPROVALS = [
  { id: "a1", title: "Send 12 follow-up emails to leads", taskId: "t1", confidence: 82, level: "l2", reasoning: "Confidence 82% — I have full Gmail and HubSpot access. Routing to L2 approval because this involves customer communications on your behalf. I've drafted personalized messages for each lead based on their last interaction.", impact: "12 outbound emails to warm leads", action: "Send emails via Gmail to: john@acme.com, sarah@xyz.com and 10 others", createdAt: "2 min ago", urgent: false },
  { id: "a2", title: "Send November invoice to Acme Corp", taskId: "t5", confidence: 61, level: "l3", reasoning: "Confidence 61% — L3 required: financial impact. Invoice total is $8,400 for November services. I've pulled hours from ClickUp and rates from your last invoice template. Please verify before I send.", impact: "$8,400 invoice via email", action: "Send invoice PDF to billing@acme.com via Gmail", createdAt: "2 hr ago", urgent: true },
